<textarea onchange="updateText('$\{m.key\}',this.value)">$\{state.text||""\}</textarea>\
</div>\
`;\
\});\
\}\
\
function updateTime(key,val)\{\
const today=todayKey();\
if(!data[today]) data[today]=\{\};\
if(!data[today][key]) data[today][key]=\{\};\
data[today][key].time=parseInt(val);\
saveLocal();\
\}\
\
function updateText(key,val)\{\
const today=todayKey();\
data[today][key].text=val;\
saveLocal();\
\}\
\
function saveLocal()\{\
localStorage.setItem("studyData",JSON.stringify(data));\
\}\
