\
let data = JSON.parse(localStorage.getItem("studyData")||"\{\}");\
\
function todayKey()\{\
const d=new Date();\
return d.toISOString().slice(0,10);\
\}\
\
function buildTimeOptions(val)\{\
let html="";\
for(let i=0;i<=720;i+=15)\{\
html+=`<option value="$\{i\}" $\{val==i?"selected":""\}>$\{i\}\uc0\u20998 </option>`;\
\}\
return html;\
\}\
\
function renderCards()\{\
const container=document.getElementById("cards");\
container.innerHTML="";\
const today=todayKey();\
if(!data[today]) data[today]=\{\};\
\
members.forEach(m=>\{\
const state=data[today][m.key]||\{time:0, text:""\};\
container.innerHTML+=`\
<div class="card">\
<h2>$\{m.name\}</h2>\
<label>\uc0\u21193 \u24375 \u26178 \u38291 </label>\
<select onchange="updateTime('$\{m.key\}',this.value)">\
$\{buildTimeOptions(state.time)\}\
</select>\
\
